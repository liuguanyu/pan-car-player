<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_normal"
    android:gravity="center_vertical"
    android:minHeight="@dimen/song_item_height"
    android:background="@drawable/song_item_background">

    <CheckBox
        android:id="@+id/checkbox_select"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"
        android:layout_marginEnd="@dimen/spacing_small" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/song_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_medium"
            android:textColor="@color/car_text_primary"
            android:singleLine="true"
            android:ellipsize="end"
            android:gravity="center_vertical" />

        <TextView
            android:id="@+id/song_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_small"
            android:textColor="@color/car_text_secondary"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:gravity="center_vertical" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/song_more"
        android:layout_width="@dimen/icon_button_size"
        android:layout_height="@dimen/icon_button_size"
        android:src="@drawable/ic_play"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Play from here"
        android:layout_marginStart="@dimen/spacing_small" />

</LinearLayout>